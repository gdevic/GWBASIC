10 REM ---- TWINKLING STARS: LOCATE/COLOR/INKEY$ DEMO ----
20 REM PRESS ANY KEY TO STOP
30 CLS
40 W = 78 : H = 22
50 FOR I = 1 TO 200
60   R = INT(RND*H)+2 : C = INT(RND*W)+1
70   COLOR INT(RND*15)+1
80   LOCATE R, C : PRINT CHR$(42+INT(RND*2)*214);
90   K$ = INKEY$ : IF K$ <> "" THEN 120
100 NEXT I
110 GOTO 50
120 COLOR 7 : CLS
130 PRINT "GOODBYE!"
140 END

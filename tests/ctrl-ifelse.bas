10 TOTAL=12: PRINT TOTAL
20 IF TOTAL=12 THEN 40 ELSE 50
30 PRINT "UNREACHABLE"
40 PRINT "GOOD": GOTO 60
50 PRINT "BAD"
60 X = 1: IF X=1 THEN IF X=2 THEN PRINT "I" ELSE PRINT "J" ELSE PRINT "K"
70 FOR I=10 TO 1 STEP -3: PRINT I;: NEXT: PRINT
80 A$ = INKEY$: PRINT "[" + A$ + "]"
90 DEF FNG$(S$) = S$ + "!"
100 PRINT FNG$("HEY")
110 GOSUB 200
120 PRINT "AT 120": END
200 PRINT "SUB": RETURN 120

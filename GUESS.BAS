10 REM ---- NUMBER GUESSING GAME ----
20 RANDOMIZE TIMER
30 N = INT(RND*100)+1
40 T = 0
50 PRINT "I AM THINKING OF A NUMBER FROM 1 TO 100."
60 INPUT "YOUR GUESS"; G
70 T = T + 1
80 IF G < N THEN PRINT "TOO LOW!" : GOTO 60
90 IF G > N THEN PRINT "TOO HIGH!" : GOTO 60
100 PRINT "YOU GOT IT IN"; T; "TRIES!"
110 INPUT "PLAY AGAIN (Y/N)"; A$
120 IF LEFT$(A$,1) = "Y" OR LEFT$(A$,1) = "y" THEN 30
130 PRINT "BYE!"
140 END
